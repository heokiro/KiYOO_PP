{
  "name": "kiyoo-pp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:kiro": "cross-env VITE_CONTENT=kiro vite",
    "dev:yooni": "cross-env VITE_CONTENT=yooni vite",
    "build": "tsc -b && vite build",
    "build:kiro": "cross-env VITE_CONTENT=kiro tsc -b && cross-env VITE_CONTENT=kiro vite build --outDir dist/kiro",
    "build:yooni": "cross-env VITE_CONTENT=yooni tsc -b && cross-env VITE_CONTENT=yooni vite build --outDir dist/yooni",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.21"
  }
}
